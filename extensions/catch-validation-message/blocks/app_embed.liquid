<div id="RestrictionModalWrapper">
  <div class="restriction-modal-content">
    <button id="CloseRestrictionModal">&times;</button>
    <div class="restriction-modal-header">
      <span class="restriction-modal-icon">⚠️</span>
      <h3 class="restriction-modal-title">Cart Restriction Notice</h3>
    </div>
    <p id="RestrictionModalMessage"></p>
    <button id="AckRestrictionModal">Understand</button>
  </div>
</div>

<script>
  (function() {
    // Cache references to our injected modal DOM nodes
    const modalWrapper = document.getElementById('RestrictionModalWrapper');
    const modalMessage = document.getElementById('RestrictionModalMessage');
    const closeBtn = document.getElementById('CloseRestrictionModal');
    const ackBtn = document.getElementById('AckRestrictionModal');

    function showPopup(text) {
      modalMessage.textContent = text;
      modalWrapper.style.display = 'flex';
    }

    function hidePopup() {
      modalWrapper.style.display = 'none';
    }

    closeBtn.addEventListener('click', hidePopup);
    ackBtn.addEventListener('click', hidePopup);

    // ==========================================
    // 🌐 THE NETWORK INTERCEPTOR ENGINE
    // ==========================================
    const nativeFetch = window.fetch;

    window.fetch = async function(...args) {
      const targetUrl = args[0];
      
      // Execute the network request natively
      const response = await nativeFetch.apply(this, args);

      // Check if this network event is pointing towards Shopify's cart adding pipeline
      if (typeof targetUrl === 'string' && targetUrl.includes('/cart/add')) {
        
        // 🌟 CATCH TARGET: 422 is returned when your Shopify Function throws a validation error
        if (response.status === 422) {
          try {
            // Clone the stream to prevent breaking parallel theme reader scripts
            const errorPayload = await response.clone().json();
            
            // Extract the custom dynamic text string compiled by your run.ts validation engine
            const errorMessage = errorPayload.description || errorPayload.message || "This item is restricted and cannot be added.";
            
            // Trigger our beautiful native popup instead of letting the theme crash!
            showPopup(errorMessage);

            // Attempt to break infinite loading spinners inside the merchant's theme
            document.querySelectorAll('[data-cart-loading], .loading-overlay__spinner, .spinner').forEach(el => {
              el.style.display = 'none';
              el.classList.remove('loading');
            });
            
            const submitButtons = document.querySelectorAll('button[type="submit"][name="add"], .product-form__submit');
            submitButtons.forEach(btn => {
              btn.removeAttribute('disabled');
              btn.classList.remove('loading');
              const loader = btn.querySelector('.loading-overlay__spinner');
              if(loader) loader.classList.add('hidden');
            });

          } catch (e) {
            console.error("Failed to safely parse validation hook error stream context:", e);
          }
        }
      }

      return response;
    };
  })();
</script>

{% schema %}
{
  "name": "Cart Restriction Alerts",
  "target": "body",
  "stylesheet": "app_embed.css",
  "settings": []
}
{% endschema %}